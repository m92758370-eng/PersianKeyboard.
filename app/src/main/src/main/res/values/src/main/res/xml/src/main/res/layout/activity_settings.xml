<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="۱) فعال‌سازی کیبورد"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnEnableKeyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="فعال‌سازی در تنظیمات اندروید" />

        <Button
            android:id="@+id/btnSwitchKeyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="انتخاب این کیبورد به‌عنوان کیبورد فعال" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="۲) متن اختصاصی هر حرف (با دوبار ضربه فعال می‌شود)"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/lettersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="۳) متن تایپ خودکار"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/autoTypeEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="6"
            android:gravity="top|start"
            android:hint="متنی که باید خودکار تایپ بشه رو اینجا بچسبون..." />

        <TextView
            android:id="@+id/speedLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="سرعت تایپ" />

        <SeekBar
            android:id="@+id/speedSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="295" />

        <Button
            android:id="@+id/btnSaveAutoType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="ذخیره متن و سرعت" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#666666"
            android:text="برای شروع تایپ خودکار: برو توی هر اپی، روی فیلد متنی ضربه بزن، این کیبورد رو انتخاب کن و دکمه ▶ روی کیبورد رو بزن. برای توقف دوباره ▶ رو بزن." />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
